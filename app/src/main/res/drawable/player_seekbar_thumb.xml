<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <size
                        android:width="14dp"
                        android:height="14dp" />
                    <solid android:color="#3C7AFFFF" />
                </shape>
            </item>
            <item
                android:left="3dp"
                android:top="3dp"
                android:right="3dp"
                android:bottom="3dp">
                <shape android:shape="oval">
                    <size
                        android:width="8dp"
                        android:height="8dp" />
                    <gradient
                        android:angle="270"
                        android:startColor="#FFFFFFFF"
                        android:endColor="#FFB7F4FF" />
                    <stroke
                        android:width="1dp"
                        android:color="#FF88E8FF" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <size
                        android:width="12dp"
                        android:height="12dp" />
                    <solid android:color="#327AFFFF" />
                </shape>
            </item>
            <item
                android:left="2.5dp"
                android:top="2.5dp"
                android:right="2.5dp"
                android:bottom="2.5dp">
                <shape android:shape="oval">
                    <size
                        android:width="7dp"
                        android:height="7dp" />
                    <gradient
                        android:angle="270"
                        android:startColor="#FFFFFFFF"
                        android:endColor="#FFD0F8FF" />
                    <stroke
                        android:width="1dp"
                        android:color="#FF79E2FF" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <shape android:shape="oval">
            <size
                android:width="1dp"
                android:height="1dp" />
            <solid android:color="#00FFFFFF" />
        </shape>
    </item>
</selector>
