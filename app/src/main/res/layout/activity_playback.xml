<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/playback_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        app:resize_mode="fit"
        app:show_buffering="never"
        app:surface_type="texture_view"
        app:use_controller="false" />

    <View
        android:id="@+id/player_dimmer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:background="#12000000"
        android:visibility="gone" />

    <ProgressBar
        android:id="@+id/player_loading"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="center"
        android:indeterminateTint="@android:color/white"
        android:visibility="gone" />

    <TextView
        android:id="@+id/player_error_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_player_panel"
        android:gravity="center"
        android:maxWidth="720dp"
        android:paddingStart="28dp"
        android:paddingTop="18dp"
        android:paddingEnd="28dp"
        android:paddingBottom="18dp"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/player_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_marginStart="42dp"
            android:layout_marginTop="38dp"
            android:background="@drawable/bg_player_panel"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="14dp"
            android:paddingEnd="18dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/player_title_text"
                android:layout_width="520dp"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@android:color/white"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/player_episode_text"
                android:layout_width="520dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#DDE8F6"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginStart="38dp"
            android:layout_marginEnd="38dp"
            android:layout_marginBottom="28dp"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_player_panel"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp">

                <TextView
                    android:id="@+id/player_current_time"
                    android:layout_width="54dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="00:00"
                    android:textColor="#F8FAFC"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <SeekBar
                    android:id="@+id/player_progress_bar"
                    style="?android:attr/seekBarStyle"
                    android:layout_width="0dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:maxHeight="18dp"
                    android:max="1000"
                    android:minHeight="18dp"
                    android:progress="0"
                    android:nextFocusDown="@id/button_play_pause"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:progressDrawable="@drawable/player_seekbar_progress"
                    android:splitTrack="true"
                    android:thumb="@drawable/player_seekbar_thumb"
                    android:thumbOffset="5dp" />

                <TextView
                    android:id="@+id/player_total_time"
                    android:layout_width="54dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="00:00"
                    android:textColor="#F8FAFC"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/player_button_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_player_panel"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingTop="6dp"
                android:paddingEnd="8dp"
                android:paddingBottom="6dp">

                <ImageView
                    android:id="@+id/button_episode_list"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="5dp"
                    android:background="@drawable/player_chip_selector"
                    android:clickable="true"
                    android:contentDescription="選集"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:nextFocusUp="@id/player_progress_bar"
                    android:padding="10dp"
                    android:src="@drawable/ic_player_playlist"
                    android:tint="@android:color/white" />

                <ImageView
                    android:id="@+id/button_previous_episode"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="5dp"
                    android:background="@drawable/player_chip_selector"
                    android:clickable="true"
                    android:contentDescription="上一集"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:nextFocusUp="@id/player_progress_bar"
                    android:padding="10dp"
                    android:src="@drawable/ic_player_skip_previous"
                    android:tint="@android:color/white" />

                <ImageView
                    android:id="@+id/button_rewind"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="5dp"
                    android:background="@drawable/player_chip_selector"
                    android:clickable="true"
                    android:contentDescription="快退"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:nextFocusUp="@id/player_progress_bar"
                    android:padding="10dp"
                    android:src="@drawable/ic_player_rewind_10"
                    android:tint="@android:color/white" />

                <ImageView
                    android:id="@+id/button_play_pause"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="5dp"
                    android:background="@drawable/player_chip_selector"
                    android:clickable="true"
                    android:contentDescription="播放"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:nextFocusUp="@id/player_progress_bar"
                    android:padding="12dp"
                    android:src="@drawable/ic_player_play"
                    android:tint="@android:color/white" />

                <ImageView
                    android:id="@+id/button_forward"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="5dp"
                    android:background="@drawable/player_chip_selector"
                    android:clickable="true"
                    android:contentDescription="快進"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:nextFocusUp="@id/player_progress_bar"
                    android:padding="10dp"
                    android:src="@drawable/ic_player_forward_10"
                    android:tint="@android:color/white" />

                <TextView
                    android:id="@+id/button_anime4k"
                    android:layout_width="58dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="5dp"
                    android:background="@drawable/player_chip_selector"
                    android:clickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:gravity="center"
                    android:nextFocusUp="@id/player_progress_bar"
                    android:paddingStart="8dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="8dp"
                    android:text="4K OFF"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/button_next_episode"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="5dp"
                    android:background="@drawable/player_chip_selector"
                    android:clickable="true"
                    android:contentDescription="下一集"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:nextFocusUp="@id/player_progress_bar"
                    android:padding="10dp"
                    android:src="@drawable/ic_player_skip_next"
                    android:tint="@android:color/white" />

                <ImageView
                    android:id="@+id/button_back_detail"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/player_chip_selector"
                    android:clickable="true"
                    android:contentDescription="返回"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:nextFocusUp="@id/player_progress_bar"
                    android:padding="10dp"
                    android:src="@drawable/ic_player_back"
                    android:tint="@android:color/white" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
